{
    "name": "ahmed-aliraqi/ui-manager",
    "description": "A powerful, class-driven UI management system for Laravel — manage layouts, pages, sections, and fields from a modern SPA dashboard.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "ui", "cms", "content-management", "fields", "sections"],
    "authors": [
        {
            "name": "Ahmed Fathy",
            "email": "fathy.dev@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.0|^12.0",
        "spatie/laravel-medialibrary": "^11.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.0",
        "nunomaduro/larastan": "^2.9"
    },
    "autoload": {
        "psr-4": {
            "AhmedAliraqi\\UiManager\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "AhmedAliraqi\\UiManager\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AhmedAliraqi\\UiManager\\UiManagerServiceProvider"
            ],
            "aliases": {
                "Ui": "AhmedAliraqi\\UiManager\\Facades\\Ui"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
